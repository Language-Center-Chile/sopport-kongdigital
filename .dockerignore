# .dockerignore for Angular SSR application
# Files and directories to ignore when building Docker image

# Dependencies
node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log

# Build outputs
dist
.angular
out-tsc

# IDE and editor files
.vscode
.idea
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache

# Environment files (to avoid leaking secrets)
.env
.env.local
.env.*.local

# Git files
.git
.gitignore
.gitattributes

# Test files
*.spec.ts
*.spec.js

# Misc
*.md
!README.md
*.log
